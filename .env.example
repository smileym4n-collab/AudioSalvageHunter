# eBay Browse API credentials. Required for live scans, not required for mock-data mode.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# Optional Telegram notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Local timezone used for display and scheduler configuration.
TZ=Europe/London

# Session signing key. Set this to a long random value before enabling auth.
APP_SECRET_KEY=change-me-to-a-long-random-secret
COOKIE_SECURE=false

# Optional local login protection.
AUTH_ENABLED=false
AUTH_USERNAME=admin
# Generate with: python3 -c "import hashlib,getpass; print('sha256$'+hashlib.sha256(getpass.getpass().encode()).hexdigest())"
AUTH_PASSWORD_HASH=
